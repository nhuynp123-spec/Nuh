 <!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nà ná na na - 21 Ngày Đêm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lexend', sans-serif; transition: all 0.5s ease; min-height: 100vh; background-color: #f8fafc; }
        .theme-female { background-color: #fff1f2; color: #e11d48; }
        .bg-female { background-color: #fb7185; color: white; }
        .theme-male { background-color: #f0f9ff; color: #0284c7; }
        .bg-male { background-color: #38bdf8; color: white; }
        .glass { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .hidden { display: none; }
        @keyframes heartFly {
            0% { transform: translateY(0) rotate(0deg); opacity: 0; }
            50% { opacity: 0.6; }
            100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }
        }
        .heart { position: fixed; bottom: -10%; z-index: -1; animation: heartFly 6s linear infinite; }
        .podium-1 { height: 110px; border-top: 5px solid #fbbf24; }
        .podium-2 { height: 80px; border-top: 5px solid #cbd5e1; }
        .podium-3 { height: 60px; border-top: 5px solid #d97706; }
    </style>
</head>
<body class="theme-female">

    <div id="view-gender" class="min-h-screen flex flex-col items-center justify-center p-6 text-center bg-white">
        <h1 class="text-3xl font-black mb-16 tracking-tighter italic">NÀ NÁ NA NA...</h1>
        <div class="space-y-6 w-full max-w-xs">
            <button onclick="pickGender('male')" class="w-full py-8 rounded-[30px] bg-blue-50 border-2 border-blue-400 text-2xl font-black text-blue-600 shadow-xl active:scale-95 transition-all">TỔNG TÀI</button>
            <button onclick="pickGender('female')" class="w-full py-8 rounded-[30px] bg-pink-50 border-2 border-pink-400 text-2xl font-black text-pink-600 shadow-xl active:scale-95 transition-all">CÔNG CHÚA</button>
        </div>
    </div>

    <div id="view-intro" class="min-h-screen hidden flex flex-col items-center justify-center p-8 text-center">
        <h1 id="intro-title" class="text-3xl font-extrabold mb-8">Hế lô!</h1>
        <div class="glass p-6 rounded-[32px] w-full max-w-sm space-y-5 text-left text-sm shadow-xl mb-12">
            <p>🔥 <b>Check-in:</b> Tạo profile cực cháy để fan nhận diện.</p>
            <p>🕵️ <b>Tăm tia:</b> Đi xem info ẩn danh, không lo bị "tóm".</p>
            <p>🏆 <b>Leo Rank:</b> Càng nhiều người tăm tia, càng dễ lọt Top 3 Vinh Quang.</p>
        </div>
        <button onclick="showView('view-auth')" id="intro-btn" class="px-16 py-4 rounded-full font-bold shadow-lg active:scale-95 transition-all">VÀO VIỆC LUÔN</button>
    </div>

    <div id="view-auth" class="min-h-screen hidden p-6 pt-10">
        <div class="flex justify-around mb-10 border-b border-black/5">
            <button id="tab-signup-btn" onclick="toggleAuth(false)" class="pb-3 border-b-4 border-current font-black text-lg">ĐĂNG KÝ</button>
            <button id="tab-login-btn" onclick="toggleAuth(true)" class="pb-3 text-gray-400 text-lg font-bold">ĐĂNG NHẬP</button>
        </div>

        <div id="form-signup" class="space-y-4">
            <input id="up-name" type="text" class="w-full p-4 rounded-2xl glass outline-none placeholder:text-current/40">
            <input id="up-room" type="text" class="w-full p-4 rounded-2xl glass outline-none placeholder:text-current/40">
            <input id="up-social" type="text" placeholder="Link Facebook/Insta (Bắt buộc)" class="w-full p-4 rounded-2xl glass outline-none border-2 border-transparent focus:border-current/50">
            <input id="up-email" type="email" class="w-full p-4 rounded-2xl glass outline-none placeholder:text-current/40">
            <input id="up-pass" type="password" placeholder="Mật khẩu (Ít nhất 6 ký tự)" class="w-full p-4 rounded-2xl glass outline-none">
            
            <label class="flex items-center space-x-3 p-2 text-[10px] font-bold opacity-60">
                <input type="checkbox" id="consent" checked class="w-4 h-4">
                <span>EM ĐỒNG Ý CHIA SẺ INFO ĐỂ KẾT NỐI ĐỒNG ĐỘI</span>
            </label>
            <button onclick="handleSignup()" id="signup-btn" class="w-full p-5 rounded-2xl font-black uppercase shadow-lg tracking-widest">Xác Nhận Profile</button>
        </div>

        <div id="form-login" class="space-y-4 hidden text-center">
            <h2 id="login-welcome" class="text-xl font-black mb-6 italic text-glow">Mừng Sếp trở lại!</h2>
            <input id="in-email" type="email" placeholder="Nhập Email" class="w-full p-4 rounded-2xl glass outline-none">
            <input id="in-pass" type="password" placeholder="Nhập Mật khẩu" class="w-full p-4 rounded-2xl glass outline-none">
            <button onclick="handleLogin()" id="login-btn" class="w-full p-5 rounded-2xl font-black uppercase shadow-lg tracking-widest">Đăng Nhập</button>
        </div>
    </div>

    <div id="view-home" class="min-h-screen hidden pb-24">
        <div id="heart-container"></div>
        <div class="p-10 text-center"><h2 class="text-2xl font-black italic tracking-tighter">BẢNG VÀNG TĂM TIA 👑</h2></div>

        <div class="flex items-end justify-center px-4 mb-12 space-x-3 h-48">
            <div class="flex flex-col items-center flex-1">
                <div id="top2-img" class="w-12 h-12 rounded-full mb-2 bg-white flex items-center justify-center text-xl shadow-md border-2 border-slate-300 overflow-hidden">🥈</div>
                <div class="podium-2 w-full glass rounded-t-3xl flex items-center justify-center font-bold text-slate-400">#2</div>
                <div id="top2-name" class="text-[10px] mt-2 font-bold truncate w-full text-center italic text-slate-500">Chưa có</div>
            </div>
            <div class="flex flex-col items-center flex-1">
                <span class="text-3xl mb-1">👑</span>
                <div id="top1-img" class="w-16 h-16 rounded-full mb-2 bg-white flex items-center justify-center text-2xl shadow-xl border-2 border-yellow-400 overflow-hidden">🥇</div>
                <div class="podium-1 w-full glass rounded-t-3xl flex items-center justify-center font-black text-yellow-500">#1</div>
                <div id="top1-name" class="text-[12px] mt-2 font-black truncate w-full text-center uppercase text-yellow-600">Đang chờ</div>
            </div>
            <div class="flex flex-col items-center flex-1">
                <div id="top3-img" class="w-12 h-12 rounded-full mb-2 bg-white flex items-center justify-center text-xl shadow-md border-2 border-amber-600 overflow-hidden">🥉</div>
                <div class="podium-3 w-full glass rounded-t-3xl flex items-center justify-center font-bold text-amber-700">#3</div>
                <div id="top3-name" class="text-[10px] mt-2 font-bold truncate w-full text-center italic text-amber-800">Chưa có</div>
            </div>
        </div>

        <div class="px-6 relative mb-10">
            <input id="main-search" oninput="searchUser()" type="text" placeholder="Tìm kiếm người ấy... (tên, phòng)" class="w-full p-5 rounded-full glass outline-none shadow-xl border-none">
            <div id="search-results" class="absolute top-full left-6 right-6 mt-3 glass rounded-[32px] hidden z-50 max-h-64 overflow-y-auto shadow-2xl"></div>
        </div>

        <div class="px-6">
            <div class="glass p-5 rounded-[32px] flex justify-between items-center border-current/10">
                <span class="text-xs font-bold opacity-50 uppercase tracking-tighter">Lượt người tăm tia bạn:</span>
                <span id="my-view-count" class="font-black text-3xl italic tracking-tighter">0</span>
            </div>
        </div>
    </div>

    <div id="view-profile" class="min-h-screen hidden p-8 pt-12">
        <div class="text-center mb-10">
            <div id="profile-avatar" class="w-28 h-28 mx-auto rounded-full bg-white mb-5 border-4 border-current flex items-center justify-center text-5xl shadow-2xl overflow-hidden"></div>
            <h2 id="profile-display-name" class="text-2xl font-black tracking-tight"></h2>
            <p id="profile-display-room" class="text-sm font-bold opacity-40 italic"></p>
        </div>
        
        <div class="max-w-xs mx-auto space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black ml-3 opacity-40 uppercase">Chỉnh sửa Bio thả thính</label>
                <textarea id="profile-bio" class="w-full p-5 h-28 rounded-[28px] glass outline-none text-sm font-medium" placeholder="Viết gì đó thật 'mlem' nào..."></textarea>
            </div>
            <div class="space-y-2">
                <label class="text-[10px] font-black ml-3 opacity-40 uppercase">Cập nhật Link MXH</label>
                <input id="profile-social" type="text" class="w-full p-5 rounded-[24px] glass outline-none text-sm font-medium">
            </div>
            <button onclick="saveProfile()" id="profile-btn" class="w-full p-5 rounded-[24px] font-black uppercase shadow-xl tracking-widest active:scale-95 transition-all">Lưu Hồ Sơ</button>
            <button onclick="handleLogout()" class="w-full p-4 text-[10px] font-black opacity-30 uppercase tracking-widest mt-4">Đăng Xuất Khỏi Hệ Thống</button>
        </div>
    </div>

    <nav id="navbar" class="fixed bottom-0 left-0 right-0 h-20 glass flex items-center justify-around hidden z-50 border-t border-black/5 shadow-2xl">
        <button onclick="showView('view-home')" class="flex flex-col items-center space-y-1"><span class="text-2xl">🏠</span><span class="text-[9px] font-black uppercase">Khám Phá</span></button>
        <button onclick="showView('view-profile')" class="flex flex-col items-center space-y-1"><span class="text-2xl">👤</span><span class="text-[9px] font-black uppercase">Hồ Sơ</span></button>
    </nav>

    <div id="user-modal" class="fixed inset-0 bg-black/50 hidden z-[100] flex items-center justify-center p-6 backdrop-blur-md">
        <div class="glass w-full max-w-xs p-10 rounded-[45px] text-center space-y-5 relative shadow-2xl border-current/20">
            <button onclick="closeModal()" class="absolute top-6 right-8 text-2xl opacity-20">✕</button>
            <div id="modal-content"></div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, updateDoc, collection, query, orderBy, limit, onSnapshot, increment } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        // CONFIG CỦA THANH
        const firebaseConfig = {
            apiKey: "AIzaSyCBEozgv9C5DjLrvgW-MJGYCsOYaPtpMj8",
            authDomain: "quan-su-78320.firebaseapp.com",
            projectId: "quan-su-78320",
            storageBucket: "quan-su-78320.firebasestorage.app",
            messagingSenderId: "443731046437",
            appId: "1:443731046437:web:6726154751f9bea5bd4fcc"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        let currentUser = null;
        let allUsers = [];
        let userVibe = 'female';

        // Gọi tên theo kiểu Việt (Ví dụ: Hải Thanh)
        function formatVNName(name) {
            const parts = name.trim().split(' ');
            return parts.length > 1 ? parts.slice(-2).join(' ') : name;
        }

        // Validate Link MXH
        function isValidSocial(link) {
            const l = link.toLowerCase();
            return l.includes('facebook.com') || l.includes('instagram.com') || l.includes('fb.com');
        }

        window.pickGender = (vibe) => {
            userVibe = vibe;
            const isNam = (vibe === 'male');
            document.body.className = isNam ? 'theme-male' : 'theme-female';
            
            // Placeholder cực Gen Z
            document.getElementById('intro-title').innerText = isNam ? "Chào Tổng Tài!" : "Chào Công Chúa!";
            document.getElementById('up-name').placeholder = isNam ? "Tên Tổng Tài là gì ạ?" : "Tên Công Chúa là gì ạ?";
            document.getElementById('up-room').placeholder = isNam ? "Phủ của Tổng Tài (Số phòng)" : "Lâu đài của Công Chúa (Số phòng)";
            document.getElementById('up-email').placeholder = isNam ? "Tổng Tài vui lòng nhập Email" : "Công Chúa vui lòng nhập Email";
            document.getElementById('login-welcome').innerText = isNam ? "Mừng Tổng Tài trở lại!" : "Chào mừng Công Chúa!";
            
            ['intro-btn','signup-btn','login-btn','profile-btn'].forEach(id => {
                document.getElementById(id).className += isNam ? " bg-male" : " bg-female";
            });
            showView('view-intro');
            createHearts();
        };

        window.showView = (id) => {
            document.querySelectorAll('div[id^="view-"]').forEach(v => v.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            document.getElementById('navbar').classList.toggle('hidden', ['view-gender','view-intro','view-auth'].includes(id));
        };

        window.toggleAuth = (isLogin) => {
            document.getElementById('form-login').classList.toggle('hidden', !isLogin);
            document.getElementById('form-signup').classList.toggle('hidden', isLogin);
            document.getElementById('tab-login-btn').className = isLogin ? 'pb-3 border-b-4 border-current font-black text-lg' : 'pb-3 text-gray-400 text-lg font-bold';
            document.getElementById('tab-signup-btn').className = !isLogin ? 'pb-3 border-b-4 border-current font-black text-lg' : 'pb-3 text-gray-400 text-lg font-bold';
        };

        window.handleSignup = async () => {
            const name = document.getElementById('up-name').value.trim();
            const room = document.getElementById('up-room').value.trim();
            const social = document.getElementById('up-social').value.trim();
            const email = document.getElementById('up-email').value.trim();
            const pass = document.getElementById('up-pass').value;

            if(!name || !room || !social || !email) return alert("Sếp ơi, điền đủ thông tin mới tạo profile được!");
            if(!isValidSocial(social)) return alert("Link MXH không hợp lệ! Phải là link FB hoặc Insta nha.");
            if(pass.length < 6) return alert("Mật khẩu phải từ 6 ký tự trở lên nha sếp.");

            try {
                const cred = await createUserWithEmailAndPassword(auth, email, pass);
                const avatar = `https://api.dicebear.com/7.x/bottts/svg?seed=${encodeURIComponent(name)}&backgroundColor=ffffff`;
                await setDoc(doc(db, "users", cred.user.uid), {
                    fullName: name, room, social, email, vibe: userVibe, views: 0, bio: "", avatar
                });
            } catch (e) { alert("Lỗi rồi: " + e.message); }
        };

        window.handleLogin = async () => {
            const email = document.getElementById('in-email').value;
            const pass = document.getElementById('in-pass').value;
            try { await signInWithEmailAndPassword(auth, email, pass); } catch (e) { alert("Thông tin đăng nhập sai rồi sếp!"); }
        };

        window.handleLogout = () => signOut(auth).then(() => location.reload());

        onAuthStateChanged(auth, async (u) => {
            if(u) {
                currentUser = u;
                const snap = await getDoc(doc(db, "users", u.uid));
                const data = snap.data();
                userVibe = data.vibe;
                document.body.className = (userVibe === 'male') ? 'theme-male' : 'theme-female';
                document.getElementById('profile-display-name').innerText = formatVNName(data.fullName);
                document.getElementById('profile-display-room').innerText = "Vị trí: Phòng " + data.room;
                document.getElementById('profile-avatar').innerHTML = `<img src="${data.avatar}" class="w-full h-full p-3">`;
                document.getElementById('profile-bio').value = data.bio || "";
                document.getElementById('profile-social').value = data.social || "";
                document.getElementById('my-view-count').innerText = data.views || 0;
                showView('view-home');
                loadLeaderboard();
                loadAllUsers();
            } else { showView('view-gender'); }
        });

        function loadLeaderboard() {
            onSnapshot(query(collection(db, "users"), orderBy("views", "desc"), limit(3)), (snap) => {
                snap.docs.forEach((d, i) => {
                    const data = d.data();
                    document.getElementById(`top${i+1}-name`).innerText = formatVNName(data.fullName);
                    document.getElementById(`top${i+1}-img`).innerHTML = `<img src="${data.avatar}" class="w-full h-full">`;
                });
            });
        }

        function loadAllUsers() {
            onSnapshot(collection(db, "users"), (snap) => {
                allUsers = snap.docs.map(d => ({ id: d.id, ...d.data() }));
            });
        }

        window.searchUser = () => {
            const q = document.getElementById('main-search').value.toLowerCase();
            const box = document.getElementById('search-results');
            if(!q) return box.classList.add('hidden');
            const res = allUsers.filter(u => u.fullName.toLowerCase().includes(q) || u.room.includes(q));
            box.innerHTML = res.map(u => `
                <div onclick="viewUser('${u.id}')" class="p-5 border-b border-black/5 flex items-center space-x-4 active:bg-black/5">
                    <img src="${u.avatar}" class="w-10 h-10 rounded-full bg-white border border-black/5">
                    <div class="text-left"><p class="font-black text-sm">${formatVNName(u.fullName)}</p><p class="text-[10px] opacity-40">Phòng ${u.room}</p></div>
                </div>
            `).join('');
            box.classList.remove('hidden');
        };

        window.viewUser = async (id) => {
            const u = allUsers.find(x => x.id === id);
            if(id !== currentUser.uid) await updateDoc(doc(db, "users", id), { views: increment(1) });
            document.getElementById('modal-content').innerHTML = `
                <img src="${u.avatar}" class="w-24 h-24 mx-auto mb-5 bg-white rounded-full p-2 shadow-xl border-2 border-current">
                <h3 class="font-black text-xl italic">${formatVNName(u.fullName)}</h3>
                <p class="text-[10px] font-black opacity-30 uppercase tracking-widest">Đến từ: Phòng ${u.room}</p>
                <div class="py-5 text-sm italic font-medium">"${u.bio || "Người này khá hướng nội, chưa viết bio..."}"</div>
                <a href="${u.social}" target="_blank" class="block p-5 rounded-2xl font-black bg-black text-white text-[11px] uppercase tracking-widest shadow-lg">Ghé Thăm Profile</a>
            `;
            document.getElementById('user-modal').classList.remove('hidden');
        };

        window.closeModal = () => document.getElementById('user-modal').classList.add('hidden');

        window.saveProfile = async () => {
            const bio = document.getElementById('profile-bio').value.trim();
            const social = document.getElementById('profile-social').value.trim();
            if(!isValidSocial(social)) return alert("Link MXH sai định dạng rồi sếp ơi!");
            await updateDoc(doc(db, "users", currentUser.uid), { bio, social });
            alert("Đã cập nhật hồ sơ thành công!");
        };

        function createHearts() {
            const container = document.getElementById('heart-container');
            setInterval(() => {
                const h = document.createElement('div');
                h.className = 'heart';
                h.innerHTML = (userVibe === 'male') ? '🔹' : '💖';
                h.style.left = Math.random() * 100 + 'vw';
                h.style.fontSize = (Math.random() * 20 + 15) + 'px';
                h.style.animationDuration = (Math.random() * 3 + 4) + 's';
                container.appendChild(h);
                setTimeout(() => h.remove(), 6000);
            }, 700);
        }
    </script>
</body>
</html>
